# Main HTTPS block for Nextcloud
nextcloud.example.com {
    tls lulaohu@protonmail.com

    # Deny access to sensitive directories/files
    @protectedPath path_regexp ^/(build|tests|config|lib|3rdparty|templates|data)/
    @protectedFiles path_regexp ^/(?:\.|autotest|occ|issue|indie|db_|console)
    respond @protectedPath 403
    respond @protectedFiles 403

    # robots.txt handling
    @robots path /robots.txt
    header @robots Content-Type "text/plain"
    respond @robots "User-agent: *\nDisallow: /\n"

    # CalDAV/CardDAV redirects
    redir /.well-known/carddav /remote.php/dav/ 301
    redir /.well-known/caldav /remote.php/dav/ 301

    # OnlyOffice integration with URL prefix rewrite
    handle_path /ds-vpath/* {
        uri strip_prefix /ds-vpath
        reverse_proxy onlyoffice-document-server:80
    }

    # Main Nextcloud reverse proxy
    reverse_proxy nextcloud-app:80
}

